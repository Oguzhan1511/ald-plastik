// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // To switch to PostgreSQL in production, change provider to "postgresql"
  // and update DATABASE_URL in .env accordingly.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Hammadde (Raw Material)
// ─────────────────────────────────────────────
model RawMaterial {
  id              String   @id @default(cuid())
  name            String   @unique
  code            String?  @unique // Hammadde kodu (örn. 951013H)
  unit            String   // gram, kg, litre, adet, vb.
  currentStock    Decimal  @default(0)
  criticalLevel   Decimal? // Opsiyonel — bu seviyenin altına düşünce uyarı
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // İlişkiler
  recipes         Recipe[]
  stockMovements  StockMovement[]

  @@map("raw_materials")
}

// ─────────────────────────────────────────────
// Ürün (Product)
// ─────────────────────────────────────────────
model Product {
  id               String   @id @default(cuid())
  name             String   @unique
  code             String?  @unique // İşletmenin ürün kodu (örn. "602051Z")
  unitWeight       Decimal? // Bir adedinin toplam gramajı (bilgi amaçlı)
  currentStock     Decimal  @default(0) // Mevcut ürün stoku (adet)
  criticalLevel    Decimal? // Bu seviyenin altına düşünce uyarı
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Bu ürünün kendi reçete satırları (bu ürünü yapmak için gerekenler)
  recipes           Recipe[]  @relation("RecipeParentProduct")
  // Bu ürünün başka ürünlerin reçetesinde bileşen olarak geçtiği satırlar
  componentInRecipes Recipe[] @relation("RecipeComponentProduct")
  productionRecords  ProductionRecord[]
  productStockMovements ProductStockMovement[]

  @@map("products")
}

// ─────────────────────────────────────────────
// Reçete / BOM Satırı (Recipe)
// Çok seviyeli BOM: bir ürün için hammadde VEYA alt ürün bileşeni
// ─────────────────────────────────────────────
model Recipe {
  id                 String      @id @default(cuid())
  productId          String      // Üst ürün (bu reçete kimin için?)

  // Bileşen — sadece biri dolu olur:
  rawMaterialId      String?     // Hammadde bileşeni
  componentProductId String?     // Alt Ürün bileşeni (çok seviyeli BOM)

  quantityPerUnit    Decimal     @default(0) // Bir adet üst ürün için gereken miktar
  wastePercentage    Decimal     @default(0) // Fire oranı (örn. 0.03 = %3)
  createdAt          DateTime    @default(now())

  product            Product      @relation("RecipeParentProduct", fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial        RawMaterial? @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  componentProduct   Product?     @relation("RecipeComponentProduct", fields: [componentProductId], references: [id], onDelete: Restrict)

  // NOT: SQLite'da nullable sütunlar içeren composite unique güvenilmez davranır.
  // Tekrar kontrolü application layer'da (findFirst + skip) yapılmaktadır.
  @@map("recipes")
}

// ─────────────────────────────────────────────
// Stok Hareketi (Stock Movement)
// MovementType values: GIRIS | URETIM_CIKISI | MANUEL_CIKIS | DUZELTME
// SQLite does not support enums — type is enforced at application layer
// ─────────────────────────────────────────────
model StockMovement {
  id                  String         @id @default(cuid())
  rawMaterialId       String
  type                String         // GIRIS | URETIM_CIKISI | MANUEL_CIKIS | DUZELTME
  amount              Decimal        // Pozitif = giriş, negatif = çıkış (tip'e göre yorum)
  date                DateTime       @default(now())
  description         String?
  productionRecordId  String?        // Üretimden geldiyse bağlantı

  rawMaterial         RawMaterial    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  productionRecord    ProductionRecord? @relation(fields: [productionRecordId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// ─────────────────────────────────────────────
// Üretim Kaydı (Production Record)
// ─────────────────────────────────────────────
model ProductionRecord {
  id            String   @id @default(cuid())
  productId     String
  quantity      Int      // Üretilen adet
  date          DateTime @default(now())
  description   String?

  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]
  productStockMovements ProductStockMovement[]

  @@map("production_records")
}

// ─────────────────────────────────────────────
// Ürün Stok Hareketi (Product Stock Movement)
// type: URETIM_GIRISI | SATIS_CIKISI | MANUEL_GIRIS | MANUEL_CIKIS | DUZELTME
// ─────────────────────────────────────────────
model ProductStockMovement {
  id                 String   @id @default(cuid())
  productId          String
  type               String   // URETIM_GIRISI | SATIS_CIKISI | MANUEL_GIRIS | MANUEL_CIKIS | DUZELTME
  quantity           Decimal  // Pozitif = giriş, negatif = çıkış
  date               DateTime @default(now())
  description        String?
  productionRecordId String?  // Üretimden geldiyse bağlantı

  product            Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  productionRecord   ProductionRecord? @relation(fields: [productionRecordId], references: [id], onDelete: SetNull)

  @@map("product_stock_movements")
}
